def format_lobby_text(sess: MafiaSession, host_name: str) -> str:
    text = (
        "🎲 *Лобби мафии*\n"
        f"👑 Ведущий: *{host_name}*\n"
        f"👥 Игроки: `{len(sess.players)}`/12\n\n"
