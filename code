def delete_later(chat_id: int, message_id: int, delay: int):
    def worker():
        time.sleep(delay)
        try:
            bot.delete_message(chat_id, message_id)
        except Exception as e:
            logger.error(f"Ошибка удаления сообщения {message_id} в чате {chat_id}: {e}")
    threading.Thread(target=worker, daemon=True).start()


def safe_send(chat_id, text, reply_markup=None, auto_delete: int = 0, retries=1):
    for _ in range(retries + 1):
        try:
            msg = bot.send_message(
                chat_id,
                text,
                parse_mode="Markdown",
                reply_markup=reply_markup,
                disable_web_page_preview=True,
                timeout=30
            )
            if auto_delete > 0:
                delete_later(chat_id, msg.message_id, auto_delete)
            return msg
        except Exception as e:
            logger.error(f"Ошибка отправки {chat_id}: {e}")
            if "timeout" not in str(e).lower() or _ == retries:
                break
            time.sleep(1)
    return None


def safe_pm(user_id, text, reply_markup=None, retries=1):
    for _ in range(retries + 1):
        try:
            bot.send_message(
                user_id,
                text,
                parse_mode="Markdown",
                reply_markup=reply_markup,
                timeout=30
            )
            logger.info(f"✅ ЛС отправлено пользователю {user_id}")
            return True
        except Exception as e:
            logger.error(f"❌ Ошибка ЛС {user_id}: {e}")
            if "timeout" not in str(e).lower() or _ == retries:
                break
            time.sleep(1)
    return False



