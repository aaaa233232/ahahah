@dataclass
class Player:
    user_id: int
    name: str
    role: Optional[str] = None
    alive: bool = True
    night_target: Optional["Player"] = None
    has_moved: bool = False


class GameState(Enum):
    LOBBY = "lobby"
    NIGHT = "night"
    DAY_VOTE = "day_vote"


class PlayerRole(Enum):
    MAFIA = "🖤 Мафия"
    DETECTIVE = "🕵️ Шериф"
    DOCTOR = "💉 Доктор"
    VILLAGER = "👨‍🌾 Мирный житель"


class MafiaSession:
    def __init__(self, chat_id: int, host_id: int):
        self.chat_id = chat_id
        self.host_id = host_id
        self.players: List[Player] = []
        self.state = GameState.LOBBY
        self.day_number = 0
        self.night_mafia_target: Optional[Player] = None
        self.doctor_saved: Optional[Player] = None
        self.day_votes: Dict[int, int] = {}
        self.in_transition: bool = False
        self.lobby_message_id: Optional[int] = None

    def add_player(self, user_id: int, name: str) -> bool:
        if any(p.user_id == user_id for p in self.players) or len(self.players) >= 12:
            return False
        self.players.append(Player(user_id, name))
        return True

    def get_player_by_user_id(self, user_id: int) -> Optional[Player]:
        return next((p for p in self.players if p.user_id == user_id), None)

    def get_alive_players(self) -> List[Player]:
        return [p for p in self.players if p.alive]

    def get_mafia_players(self) -> List[Player]:
        return [p for p in self.get_alive_players() if p.role == PlayerRole.MAFIA.value]

    def get_detective(self) -> Optional[Player]:
        return next((p for p in self.players if p.role == PlayerRole.DETECTIVE.value and p.alive), None)

    def get_doctor(self) -> Optional[Player]:
        return next((p for p in self.players if p.role == PlayerRole.DOCTOR.value and p.alive), None)

    def get_player_by_number(self, n: int) -> Optional[Player]:
        alive = self.get_alive_players()
        return alive[n] if 0 <= n < len(alive) else None

    def assign_roles(self) -> bool:
        total = len(self.players)
        if total < 4:
            return False
        mafia_count = max(1, total // 3)
        roles = (
            [PlayerRole.MAFIA.value] * mafia_count +
            [PlayerRole.DETECTIVE.value, PlayerRole.DOCTOR.value] +
            [PlayerRole.VILLAGER.value] * (total - mafia_count - 2)
        )
        random.shuffle(roles)
        for p, r in zip(self.players, roles):
            p.role = r
            p.has_moved = False
        return True

    def all_roles_moved(self) -> bool:
        if self.state == GameState.NIGHT:
            mafias = self.get_mafia_players()
            if any(p.alive and not p.has_moved for p in mafias):
                return False
            det = self.get_detective()
            if det and det.alive and not det.has_moved:
                return False
            doc = self.get_doctor()
            if doc and doc.alive and not doc.has_moved:
                return False
            return True
        elif self.state == GameState.DAY_VOTE:
            alive_count = len(self.get_alive_players())
            return len(self.day_votes) == alive_count
        return False

    def check_game_end(self) -> bool:
        alive = self.get_alive_players()
        alive_mafia = len(self.get_mafia_players())
        alive_villagers = len(alive) - alive_mafia

        if alive_mafia == 0:
            safe_send(self.chat_id, "🎉 *Мирные победили!*", auto_delete=180)
            sessions.pop(self.chat_id, None)
            return True

        if alive_mafia >= alive_villagers:
            safe_send(self.chat_id, "🖤 *Мафия победила!*", auto_delete=180)
            sessions.pop(self.chat_id, None)
            return True

        return False


