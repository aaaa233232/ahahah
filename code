    player = sess.get_player_by_user_id(user_id)
    if not player or not player.alive:
        bot.answer_callback_query(call.id, "❌ Вы уже выбыли из игры.", show_alert=True)
        return

    if player.has_moved:
        bot.answer_callback_query(call.id, "❌ Вы уже сделали выбор.", show_alert=True)
        return

    parts = data.split("_", 1)
    if len(parts) < 2:
        bot.answer_callback_query(call.id, "❌ Ошибка данных.", show_alert=True)
        return

    role_type = parts[0]
    idx_str = parts[1]

    if idx_str == "skip":
        player.has_moved = True
        safe_pm(user_id, "⏰ Вы пропустили ход.")
        if sess.all_roles_moved():
            next_phase(sess.chat_id)
        bot.answer_callback_query(call.id)
        return

    try:
        target_idx = int(idx_str)
        target = sess.get_player_by_number(target_idx)
        if not target:
            safe_pm(user_id, "❌ Игрок не найден.")
            bot.answer_callback_query(call.id)
            return
    except Exception:
        safe_pm(user_id, "❌ Некорректный выбор.")
        bot.answer_callback_query(call.id)
        return

    # 🖤 Мафия — не может убить себя
    if role_type == "mafia":
        if sess.state != GameState.NIGHT:
            safe_pm(user_id, "⏰ Сейчас не ночь или не ход мафии.")
            bot.answer_callback_query(call.id)
            return
        if target.user_id == user_id:
            safe_pm(user_id, "❌ Вы не можете выбрать себя в качестве жертвы.")
            bot.answer_callback_query(call.id)
            return
        player.night_target = target
        player.has_moved = True
        safe_pm(user_id, f"🖤 Вы выбрали цель: *{target.name}*.")
        if sess.all_roles_moved():
            next_phase(sess.chat_id)
        bot.answer_callback_query(call.id)

    # 🕵️ Шериф — не может проверить себя
    elif role_type == "det":
        if sess.state != GameState.NIGHT:
            safe_pm(user_id, "⏰ Сейчас не ночь или не ход шерифа.")
            bot.answer_callback_query(call.id)
            return
        if target.user_id == user_id:
            safe_pm(user_id, "❌ Вы не можете проверить себя.")
            bot.answer_callback_query(call.id)
            return
        result = "🖤 Мафия!" if target.role == PlayerRole.MAFIA.value else "🤝 Мирный!"
        player.has_moved = True
        safe_pm(user_id, f"🔍 *{target.name}*\n{result}")
        if sess.all_roles_moved():
            next_phase(sess.chat_id)
        bot.answer_callback_query(call.id)

    # 💉 Доктор
    elif role_type == "doc":
        if sess.state != GameState.NIGHT:
            safe_pm(user_id, "⏰ Сейчас не ночь или не ход доктора.")
            bot.answer_callback_query(call.id)
            return
        sess.doctor_saved = target
        player.has_moved = True
        safe_pm(user_id, f"💉 Вы спасаете: *{target.name}*.")
        if sess.all_roles_moved():
            next_phase(sess.chat_id)
        bot.answer_callback_query(call.id)

    # ⚖️ День — голосование
    elif role_type == "day":
        if sess.state != GameState.DAY_VOTE:
            safe_pm(user_id, "⏰ Сейчас не дневное голосование.")
            bot.answer_callback_query(call.id)
            return
        if user_id in sess.day_votes:
            safe_pm(user_id, "❌ Вы уже голосовали.")
            bot.answer_callback_query(call.id)
            return
        sess.day_votes[user_id] = target.user_id
        safe_send(sess.chat_id, f"✅ *{player.name}* голосует за *{target.name}*.", auto_delete=90)
        if sess.all_roles_moved():
            next_phase(sess.chat_id)
        bot.answer_callback_query(call.id)


if __name__ == "__main__":
    logger.info("🤖 Мафия бот запущен. Ожидаем сообщения...")
    bot.infinity_polling(
        none_stop=True,
        timeout=60,
        allowed_updates=["message", "callback_query"]
    )

