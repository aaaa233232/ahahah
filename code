def start_phase_timer(sess: MafiaSession, duration: int):
    def timer():
        time.sleep(duration)
        if sess.chat_id in sessions:
            next_phase(sess.chat_id)
    threading.Thread(target=timer, daemon=True).start()


def next_phase(chat_id: int):
    sess = sessions.get(chat_id)
    if not sess:
        return

    if sess.in_transition:
        logger.warning(f"Повторный вызов next_phase пропущен (chat_id={chat_id})")
        return

    sess.in_transition = True
    logger.info(f"Переход фазы: {sess.state.value}")

    try:
        if sess.state == GameState.NIGHT:
            votes = [
                p.night_target.user_id
                for p in sess.get_mafia_players()
                if p.night_target
            ]
            if votes:
                vote_count = Counter(votes)
                target_user_id = vote_count.most_common(1)[0][0]
                sess.night_mafia_target = sess.get_player_by_user_id(target_user_id)
            else:
                sess.night_mafia_target = None

            killed = sess.night_mafia_target
            if killed and killed != sess.doctor_saved:
                killed.alive = False
                safe_send(sess.chat_id, f"🌙 *Ночью {sess.day_number} был убит*: `{killed.name}` 💀", auto_delete=180)
            else:
                safe_send(sess.chat_id, f"🌙 *Ночь {sess.day_number}: никто не погиб.* 😌", auto_delete=120)

            for p in sess.players:
                p.night_target = None
                p.has_moved = False

            sess.night_mafia_target = None
            sess.doctor_saved = None

            if sess.check_game_end():
                return

            sess.day_number += 1
            sess.state = GameState.DAY_VOTE
            sess.day_votes.clear()
            alive_players = sess.get_alive_players()
            safe_send(
                sess.chat_id,
                f"☀️ *День {sess.day_number}*\n"
                f"Начинается обсуждение и голосование.\n\n"
                f"*Выберите, кого казнить:*",
                create_role_keyboard(alive_players, "day")
            )

        elif sess.state == GameState.DAY_VOTE:
            if sess.all_roles_moved():
                if sess.day_votes:
                    vote_count = Counter(sess.day_votes.values())
                    loser_id = vote_count.most_common(1)[0][0]
                    loser = next(p for p in sess.players if p.user_id == loser_id)
                    loser.alive = False
                    safe_send(
                        sess.chat_id,
                        f"⚖️ *День {sess.day_number}: казнён*: `{loser.name}` ({loser.role})",
                        auto_delete=240
                    )
                else:
                    safe_send(sess.chat_id, f"⚖️ *День {sess.day_number}: никто не казнён.*", auto_delete=120)

                if sess.check_game_end():
                    return

                sess.state = GameState.NIGHT
                sess.day_votes.clear()

                alive_players = sess.get_alive_players()
                for p in sess.players:
                    p.night_target = None
                    p.has_moved = False

                for p in sess.players:
                    if p.role == PlayerRole.MAFIA.value and p.alive:
                        safe_pm(
                            p.user_id,
                            f"🌙 *Ночь {sess.day_number}*\n"
                            f"🖤 *Мафия*\n"
                            f"Выберите жертву:",
                            create_role_keyboard(alive_players, "mafia")
                        )
                    elif p.role == PlayerRole.DETECTIVE.value and p.alive:
                        safe_pm(
                            p.user_id,
                            f"🌙 *Ночь {sess.day_number}*\n"
                            f"🕵️ *Шериф*\n"
                            f"Выберите игрока для проверки:",
                            create_role_keyboard(alive_players, "det")
                        )
                    elif p.role == PlayerRole.DOCTOR.value and p.alive:
                        safe_pm(
                            p.user_id,
                            f"🌙 *Ночь {sess.day_number}*\n"
                            f"💉 *Доктор*\n"
                            f"Выберите, кого лечить:",
                            create_role_keyboard(alive_players, "doc")
                        )
                    else:
                        safe_pm(
                            p.user_id,
                            f"👨‍🌾 *Ночь {sess.day_number}: вы мирный*\n"
                            f"🌙 Спите спокойно..."
                        )

                safe_send(sess.chat_id, f"🌙 *Ночь {sess.day_number} началась!* Ходите в ЛС боту.", auto_delete=60)
                start_phase_timer(sess, 60)
            else:
                update_vote_status(sess)

    finally:
        sess.in_transition = False


