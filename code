                chat_id,
                "⚠️ В этом чате уже идёт игра.",
                main_keyboard(),
                auto_delete=30
            )
            return

    sess = MafiaSession(chat_id, message.from_user.id)
    sessions[chat_id] = sess

    try:
        host_name = message.from_user.first_name
    except Exception:
        host_name = "Ведущий"

    text = format_lobby_text(sess, host_name)
    msg = safe_send(chat_id, text, lobby_keyboard())
    if msg:
        sess.lobby_message_id = msg.message_id



